{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capabilities for the Upscalar window",
  "windows": ["main"],
  "local": true,
  "remote": {
    "urls": ["http://localhost:*", "http://127.0.0.1:*"]
  },
  "permissions": ["core:default", "dialog:default", "opener:default", "opener:allow-open-url"]
}
