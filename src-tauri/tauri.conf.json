{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Upscalar",
  "version": "0.1.0",
  "identifier": "dev.upscalar.app",
  "build": {
    "frontendDist": "../ui"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Upscalar",
        "label": "main",
        "url": "index.html",
        "width": 1280,
        "height": 900,
        "minWidth": 900,
        "minHeight": 640,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
